# 00-core.zsh
# 基础核心工具

# 这是整个框架里最基础的一层
# 原则
# 只放通用 轻量 低依赖的函数
# 不放具体业务逻辑
# 不依赖后续模块
# 尽量不调用外部重命令

# 这个文件会被 init.zsh 最先加载

# --------------------------------------------------
# 调试开关
# --------------------------------------------------
# ZSH_DEBUG 用于控制 zsh_log_debug 是否输出调试信息

# 默认值是 0 (关闭)
# 推荐调试方式：
#   ZSH_DEBUG=1 zsh -lic 'exit'
# 如果要在当前 shell 中连续测试，也可以：
#   export ZSH_DEBUG=1
#   zsh -lic 'exit'
#   unset ZSH_DEBUG
typeset -g ZSH_DEBUG="${ZSH_DEBUG:-0}"

# --------------------------------------------------
#  zsh_source_optional
# --------------------------------------------------
# 安全地 source 一个可选文件

# - 在模块化框架里不是每个文件都一定存在
# - 如果每次都直接 source 一旦文件缺失就会报错
zsh_source_optional() {
  # 第一个参数是要加载的文件路径
  local file="$1"

  # 如果参数为空 直接返回
  [[ -n "$file" ]] || return 0

  # -r 比单纯检查存在更实用 因为 source 需要的是可读性
  [[ -r "$file" ]] || return 0

  # 在当前 shell 中加载该文件
  # 必须 source 不能开子进程 否则文件里的变量和函数不会进入当前 shell
  source "$file"
}

# --------------------------------------------------
# zsh_has_cmd
# --------------------------------------------------
# 判断某个命令是否在当前 PATH 中可用

# 为什么不用 command -v
# - command -v 当然也可以
# - 但在 zsh 中 直接使用内建的 commands 哈希表更轻量 也更符合 zsh 风格
#
# 返回值约定
# - 命令存在 返回 0 成功
# - 命令不存在 返回 1 失败
zsh_has_cmd() {
  # $+commands[name] 在 zsh 中表示 commands 这个哈希表里是否有这个键
  # 存在时结果为 1 不存在为 0
  #
  # (( ... )) 是算术上下文
  # - 非 0 视为成功
  # - 0 视为失败
  (( $+commands[$1] ))
}

# --------------------------------------------------
# zsh_is_interactive
# --------------------------------------------------
# 判断当前 shell 是否是交互式 shell

# 判定方法
# 查看特殊参数 $- 是否包含字符 i
# 在 shell 里 $- 保存当前 shell 选项标志
# 交互式 shell 通常会包含 i
zsh_is_interactive() {
  [[ $- == *i* ]]
}

# --------------------------------------------------
# zsh_is_login
# --------------------------------------------------
# 判断当前 shell 是否是 login shell

# 这里使用 zsh 的选项检测语法
# [[ -o login ]] 表示当前 shell 是否开启了 login 选项
zsh_is_login() {
  [[ -o login ]]
}

# --------------------------------------------------
# zsh_log_debug
# --------------------------------------------------
# 在调试模式下输出调试日志

zsh_log_debug() {
  # 如果 ZSH_DEBUG 不是 1 就不输出任何内容 直接成功返回
  [[ "${ZSH_DEBUG:-0}" == "1" ]] || return 0

  # 把全部参数原样拼成一条调试信息输出到 stderr
  # - 避免污染正常命令输出
  # - 在调试日志和普通输出之间做分流
  print -r -- "[zsh-debug] $*" >&2
}

# --------------------------------------------------
# zsh_ensure_dir
# --------------------------------------------------
# 确保某个目录存在

zsh_ensure_dir() {
  local dir="$1"

  # 空值直接跳过
  [[ -n "$dir" ]] || return 0

  # 如果目录已存在 则无需处理
  [[ -d "$dir" ]] && return 0

  # 尝试创建目录
  # -p
  # 中间父目录不存在时会一起创建
  # 已存在时不报错
  mkdir -p "$dir" 2>/dev/null
}
